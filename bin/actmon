#!/usr/bin/env bash
#
# actmon — terminal Activity Monitor for macOS
# https://github.com/kejerial/actmon
#
set -euo pipefail

VERSION="0.1.0"
TOP_N=10
SHOW_CPU=0
SHOW_MEM=0
SHOW_ENERGY=0
EXPLICIT_METRIC=0  # set when any --cpu/--memory/--energy flag is used
NO_COLOR_FLAG=0    # set by --no-color
FILTER=""          # case-insensitive regex on command name; empty = no filter
THRESHOLD=""       # broadcast minimum; per-section flags override (empty = none)
CPU_MIN=""         # minimum %CPU to display (empty = inherit THRESHOLD)
MEM_MIN=""         # minimum MB to display (empty = inherit THRESHOLD)
ENERGY_MIN=""      # minimum raw power value to display (empty = inherit THRESHOLD)
JSON_FLAG=0        # set by --json

# Alert thresholds. Calm machines render with no color; only stressed rows
# light up. Red = critical, yellow = warming, otherwise default.
THRESH_SWAP_RED=75       # swap % used
THRESH_SWAP_YEL=50
THRESH_LOAD_RED_MULT=1.0   # load avg vs hw.ncpu
THRESH_LOAD_YEL_MULT=0.75
THRESH_MEMFREE_RED_PCT=5   # free mem as % of total
THRESH_MEMFREE_YEL_PCT=15
THRESH_PROC_CPU_RED=50    # per-process %CPU
THRESH_PROC_CPU_YEL=25

# ANSI color codes — populated by init_colors based on TTY/NO_COLOR/--no-color.
C_RED=""
C_YEL=""
C_RST=""

usage() {
  cat <<'EOF'
actmon — terminal Activity Monitor for macOS

USAGE
  actmon [options]

OPTIONS
  -n, --top N        number of processes per section (default: 10)
  -c, --cpu          show only the CPU section
  -m, --memory       show only the memory section
  -e, --energy       show only the energy section
  -f, --filter PAT   case-insensitive regex on command name; only matching rows show
  -t, --threshold N  hide rows below N in every section
                       CPU: N is %CPU · MEMORY: N is MB · ENERGY: N is raw power
  --cpu-min N        hide CPU rows below N %CPU
  --mem-min N        hide MEMORY rows below N MB
  --energy-min N     hide ENERGY rows below N raw power
  -j, --json         emit structured JSON instead of the dashboard
      --no-color     disable ANSI color (also auto-disabled when stdout is
                     not a TTY or NO_COLOR is set in the environment)
  -h, --help         show this help

EXAMPLES
  actmon                              full dashboard, top 10 each
  actmon --top 5                      top 5 per section
  actmon --memory                     only memory section
  actmon --cpu --energy               CPU + energy (no memory)
  actmon --filter 'chrome|safari'     only browser processes
  actmon --filter '^WindowServer$'    exact-match a single process
  actmon --cpu --threshold 5          CPU section, hide anything under 5%
  actmon --mem-min 500                hide memory rows under 500 MB
  actmon --filter chrome --top 5      top 5 chrome-ish rows per section
  actmon --json                       machine-readable JSON snapshot
  actmon --json --memory -n 5         JSON, memory section only, top 5

NOTES
  • Multiple metric flags can be combined.
  • --filter + --threshold/--*-min are applied before --top.
  • --threshold broadcasts to all sections; per-section flags override it.
  • In --json mode, header keys are always present; top_* arrays are
    omitted when their section is excluded.
  • The system summary header is always shown.
  • macOS only (uses BSD `top -stats`).
EOF
}

die() {
  echo "actmon: $*" >&2
  echo "       try 'actmon --help'" >&2
  exit 2
}

# Decide whether to emit ANSI colors. Auto-disable when stdout isn't a TTY,
# NO_COLOR is set (https://no-color.org), or --no-color was passed.
init_colors() {
  if [[ $NO_COLOR_FLAG -eq 1 ]] || [[ -n "${NO_COLOR:-}" ]] || [[ ! -t 1 ]]; then
    C_RED=""
    C_YEL=""
    C_RST=""
  else
    C_RED=$'\033[31m'
    C_YEL=$'\033[33m'
    C_RST=$'\033[0m'
  fi
}

# Classify a numeric value against (red_threshold, yellow_threshold). Echoes
# the ANSI escape (or empty string). Comparison is "value > threshold".
color_for() {
  local val="$1" red="$2" yel="$3"
  awk -v v="$val" -v r="$red" -v y="$yel" \
      -v cr="$C_RED" -v cy="$C_YEL" 'BEGIN {
    if (v + 0 > r + 0)      printf "%s", cr
    else if (v + 0 > y + 0) printf "%s", cy
  }'
}

# Emit "<pid>\t<name>" for every process. We derive <name> ourselves rather
# than trusting `top -stats command`, which for some binaries (notably
# versioned launchers like Claude Code's `versions/2.1.139` shim) reports
# the trailing path segment — which can be a version string with no letters.
# That defeats the whole point of "what is eating my CPU".
#
# Heuristic: take basename of `ps comm` (full exe path on macOS). If it has
# no letters (pure digits/dots), walk up parent segments looking for the
# first segment that has letters and isn't a generic container directory
# (versions, MacOS, Contents, etc.). For .app bundles strip the suffix.
build_pid_name_map() {
  /bin/ps -axwwo pid=,comm= 2>/dev/null | awk '
    function is_bogus(s) {
      return s !~ /[A-Za-z]/
    }
    function is_generic(s) {
      return s == "versions" || s == "Versions" || s == "MacOS"     \
          || s == "Contents" || s == "Resources" || s == "Helpers"  \
          || s == "Frameworks" || s == "Library" || s == "bin"      \
          || s == "sbin" || s == "libexec" || s == "current"        \
          || s == "latest"
    }
    function strip_app(s) {
      sub(/\.app$/, "", s)
      return s
    }
    {
      pid = $1
      sub(/^[[:space:]]*[0-9]+[[:space:]]+/, "", $0)
      path = $0
      n = split(path, parts, "/")
      name = strip_app(parts[n])
      if (is_bogus(name)) {
        for (i = n - 1; i >= 1; i--) {
          cand = strip_app(parts[i])
          if (cand == "") continue
          if (is_bogus(cand)) continue
          if (is_generic(cand)) continue
          name = cand
          break
        }
      }
      if (name == "") name = parts[n]
      printf "%s\t%s\n", pid, name
    }
  '
}

# Capture one `top -l 2 -s 1` snapshot (all processes, second sample only) into
# the global TOP_SNAPSHOT. Two samples are needed so CPU% is a meaningful delta
# (single sample reports 0.0 for everything since there's no prior to diff
# against). -s 1 = 1s between samples (top requires an integer here). Doing this
# once and then sorting in awk per section avoids the per-section 1s wait.
capture_top_snapshot() {
  TOP_SNAPSHOT=$(
    top -l 2 -s 1 -stats pid,command,cpu,mem,power 2>/dev/null \
      | awk 'BEGIN { sample = 0 }
             /^Processes:/ { sample++ }
             sample == 2'
  )
}

build_section() {
  local title="$1" val_col="$2" n="$3" pid_map="$4" filter="$5" min_val="$6"

  printf '%s\n' "$title"

  printf '%s\n' "$TOP_SNAPSHOT" \
    | awk -v vcol="$val_col" -v topn="$n" -v width=20 -v pid_map="$pid_map" \
          -v filter="$filter" -v min_val="$min_val" \
          -v cpu_red="$THRESH_PROC_CPU_RED" -v cpu_yel="$THRESH_PROC_CPU_YEL" \
          -v c_red="$C_RED" -v c_yel="$C_YEL" -v c_rst="$C_RST" '
      function make_bar(len,    s, i) {
        s = ""
        for (i = 1; i <= width; i++) s = s (i <= len ? "█" : "░")
        return s
      }
      # Color a process row only when its %CPU crosses a threshold. Memory
      # and energy rows stay default — context, not alert.
      function row_color(cpu_num) {
        if (cpu_num + 0 > cpu_red + 0) return c_red
        if (cpu_num + 0 > cpu_yel + 0) return c_yel
        return ""
      }
      function mem_to_mb(s,    n) {
        n = s + 0
        if (s ~ /K$/) return n / 1024
        if (s ~ /G$/) return n * 1024
        if (s ~ /T$/) return n * 1024 * 1024
        return n
      }
      function trim(s) {
        gsub(/^[[:space:]]+|[[:space:]]+$/, "", s)
        return s
      }

      BEGIN {
        nrows = 0; in_data = 0
        if (pid_map != "") {
          while ((getline line < pid_map) > 0) {
            tab = index(line, "\t")
            if (tab > 0) {
              p = substr(line, 1, tab - 1)
              nm = substr(line, tab + 1)
              pid_name[p] = nm
            }
          }
          close(pid_map)
        }
      }

      /^PID/ && /COMMAND/ {
        pid_p = index($0, "PID")
        cmd_p = index($0, "COMMAND")
        cpu_p = index($0, "%CPU")
        mem_p = index($0, "MEM")
        pwr_p = index($0, "POWER")
        in_data = 1
        next
      }

      in_data && pid_p {
        pid     = trim(substr($0, pid_p, cmd_p - pid_p))
        cmd     = trim(substr($0, cmd_p, cpu_p - cmd_p))
        if (pid in pid_name) cmd = pid_name[pid]
        cpu_str = trim(substr($0, cpu_p, mem_p - cpu_p))
        mem_str = trim(substr($0, mem_p, pwr_p - mem_p))
        pwr_str = trim(substr($0, pwr_p))
        # top -l 2 appends [+-] when a value changed since the prior sample;
        # strip it for clean column alignment and unit parsing.
        sub(/[+-]$/, "", cpu_str)
        sub(/[+-]$/, "", mem_str)
        sub(/[+-]$/, "", pwr_str)

        if (vcol == "%CPU") {
          val_num  = cpu_str + 0
          val_disp = sprintf("%5.1f%%", val_num)
        } else if (vcol == "MEM") {
          val_num  = mem_to_mb(mem_str)
          val_disp = sprintf("%6s", mem_str)
        } else {
          val_num  = pwr_str + 0
          val_disp = sprintf("%6.1f", val_num)
        }

        # Apply --filter and --threshold before scoring/sorting. Filter is
        # case-insensitive regex on the (possibly ps-derived) command name;
        # min_val is the numeric floor for the section'\''s primary metric.
        if (filter != "" && tolower(cmd) !~ tolower(filter)) next
        if (min_val != "" && val_num + 0 < min_val + 0) next

        if (length(cmd) > 24) cmd = substr(cmd, 1, 23) "…"

        nrows++
        v_num[nrows]  = val_num
        v_disp[nrows] = val_disp
        v_pid[nrows]  = pid
        v_cmd[nrows]  = cmd
        v_cpu[nrows]  = cpu_str + 0
      }

      END {
        # Selection sort for the top `topn` rows by val_num desc. O(topn * nrows)
        # is fine — topn is small (default 10) and nrows is a few hundred.
        if (topn > nrows) topn = nrows
        for (i = 1; i <= topn; i++) {
          best = i
          for (j = i + 1; j <= nrows; j++) {
            if (v_num[j] > v_num[best]) best = j
          }
          if (best != i) {
            tn = v_num[i];  v_num[i]  = v_num[best];  v_num[best]  = tn
            td = v_disp[i]; v_disp[i] = v_disp[best]; v_disp[best] = td
            tp = v_pid[i];  v_pid[i]  = v_pid[best];  v_pid[best]  = tp
            tc = v_cmd[i];  v_cmd[i]  = v_cmd[best];  v_cmd[best]  = tc
            tx = v_cpu[i];  v_cpu[i]  = v_cpu[best];  v_cpu[best]  = tx
          }
        }

        max_val = (topn >= 1 && v_num[1] > 0 ? v_num[1] : 1)
        for (i = 1; i <= topn; i++) {
          bar_cells = int(v_num[i] / max_val * width)
          if (bar_cells > width) bar_cells = width
          if (bar_cells < 0)     bar_cells = 0
          rc = row_color(v_cpu[i])
          bar = make_bar(bar_cells)
          if (rc != "") {
            printf "  %-7s  %-24s  %s%s%s  %s%s%s\n", \
                   v_pid[i], v_cmd[i], rc, v_disp[i], c_rst, rc, bar, c_rst
          } else {
            printf "  %-7s  %-24s  %s  %s\n", v_pid[i], v_cmd[i], v_disp[i], bar
          }
        }
      }
    '
  printf '\n'
}

to_mb() {
  awk -v s="$1" 'BEGIN {
    n = s + 0
    if      (s ~ /K$/) printf "%.0f", n / 1024
    else if (s ~ /G$/) printf "%.0f", n * 1024
    else if (s ~ /T$/) printf "%.0f", n * 1024 * 1024
    else               printf "%.0f", n
  }'
}

human_mb() {
  awk -v m="$1" 'BEGIN {
    if (m+0 >= 1024) printf "%dG", (m/1024) + 0.5
    else             printf "%dM", m+0
  }'
}

get_cols() {
  local c=""
  c=$(tput cols 2>/dev/null) || c=""
  c=${c:-${COLUMNS:-100}}
  [[ "$c" =~ ^[0-9]+$ ]] || c=100
  if (( c < 50 )); then c=50; fi
  echo "$c"
}

# visible width of an annotation string — treats common multi-byte glyphs
# (·, —) as one column so we don't over-shrink the bar
vis_len() {
  awk -v s="$1" 'BEGIN {
    gsub(/·/, ".", s)
    gsub(/—/, "-", s)
    print length(s)
  }'
}

# make_bar WIDTH DENOM PAIR1 [PAIR2 ...]
# Each PAIR is "value:glyph". Cells per pair = round(value/denom*width).
# Overflow is clamped, leftover is padded with ░. Output: ▕…▏ (no newline).
make_bar() {
  awk -v width="$1" -v denom="$2" -v args="$*" '
    BEGIN {
      n = split(args, a, " ")
      out = ""
      used = 0
      for (i = 3; i <= n; i++) {
        if (split(a[i], part, ":") < 2) continue
        v = part[1] + 0
        g = part[2]
        cells = int(v / denom * width + 0.5)
        if (used + cells > width) cells = width - used
        if (cells < 0) cells = 0
        for (j = 0; j < cells; j++) out = out g
        used += cells
      }
      while (used < width) { out = out "░"; used++ }
      printf "▕%s▏", out
    }'
}

build_load_row() {
  local label="$1" period="$2" loadv="$3" ncpu="$4" width="$5"
  local bar pct_str red yel color
  bar=$(make_bar "$width" "$ncpu" "${loadv}:█")
  pct_str=$(awk -v l="$loadv" -v n="$ncpu" 'BEGIN {
    r = l / n
    if (r >= 1.0) print "saturated"
    else          printf "%d%%", r * 100
  }')
  red=$(awk -v n="$ncpu" -v m="$THRESH_LOAD_RED_MULT" 'BEGIN { printf "%.4f", n*m }')
  yel=$(awk -v n="$ncpu" -v m="$THRESH_LOAD_YEL_MULT" 'BEGIN { printf "%.4f", n*m }')
  color=$(color_for "$loadv" "$red" "$yel")
  if [[ -n "$color" ]]; then
    printf '  %-8s %-3s %s%-7s%s%s%s%s  %s%s%s\n' \
      "$label" "$period" "$color" "$loadv" "$C_RST" \
      "$color" "$bar" "$C_RST" \
      "$color" "$pct_str" "$C_RST"
  else
    printf '  %-8s %-3s %-7s%s  %s\n' "$label" "$period" "$loadv" "$bar" "$pct_str"
  fi
}

# Populate H_* globals with one consistent snapshot of system state.
# Called once and reused by the dashboard renderer and the JSON emitter.
collect_header_data() {
  local top_h mem_line mu mw mc boot_epoch now_epoch

  H_NOW_HMS=$(date '+%H:%M:%S')
  H_TIMESTAMP=$(date -u '+%Y-%m-%dT%H:%M:%SZ')

  top_h=$(top -l 1 -n 0 2>/dev/null)

  H_LOAD_RAW=$(awk -F': ' '/^Load Avg:/ { sub(/[[:space:]]+$/,"",$2); print $2 }' <<<"$top_h")
  IFS=', ' read -r H_LOAD1 H_LOAD5 H_LOAD15 <<<"$H_LOAD_RAW"

  H_CPU_USER=$(awk -F'[ ,%]+' '/^CPU usage:/ { print $3 }' <<<"$top_h")
  H_CPU_SYS=$(awk  -F'[ ,%]+' '/^CPU usage:/ { print $5 }' <<<"$top_h")
  H_CPU_IDLE=$(awk -F'[ ,%]+' '/^CPU usage:/ { print $7 }' <<<"$top_h")

  # PhysMem: <U> used (<W> wired, <C> compressor), <F> unused.
  mem_line=$(awk '/^PhysMem:/' <<<"$top_h")
  mu=$(sed -E 's/^PhysMem: ([0-9]+[KMGT]?).*/\1/'           <<<"$mem_line")
  mw=$(sed -E 's/.*\(([0-9]+[KMGT]?) wired.*/\1/'           <<<"$mem_line")
  mc=$(sed -E 's/.*wired, ([0-9]+[KMGT]?) compressor.*/\1/' <<<"$mem_line")
  H_MEM_USED_MB=$(to_mb "$mu")
  H_MEM_WIRED_MB=$(to_mb "$mw")
  H_MEM_COMP_MB=$(to_mb "$mc")

  H_HW_MEMSIZE=$(sysctl -n hw.memsize)
  H_MEM_TOTAL_MB=$(awk -v b="$H_HW_MEMSIZE" 'BEGIN { printf "%.0f", b/1048576 }')
  H_MEM_APP_MB=$(( H_MEM_USED_MB - H_MEM_WIRED_MB - H_MEM_COMP_MB ))
  if (( H_MEM_APP_MB < 0 )); then H_MEM_APP_MB=0; fi
  H_MEM_FREE_MB=$(( H_MEM_TOTAL_MB - H_MEM_USED_MB ))
  if (( H_MEM_FREE_MB < 0 )); then H_MEM_FREE_MB=0; fi

  H_HW_MODEL=$(sysctl -n hw.model)
  H_HW_NCPU=$(sysctl -n hw.ncpu)
  H_HW_TOTAL_GB=$(awk -v b="$H_HW_MEMSIZE" 'BEGIN { printf "%.1f", b/1073741824 }')

  H_SWAP_TOTAL_GB=$(sysctl -n vm.swapusage 2>/dev/null | awk '{ gsub(/M/,"",$3); printf "%.1f", $3/1024 }')
  H_SWAP_USED_GB=$(sysctl -n vm.swapusage 2>/dev/null  | awk '{ gsub(/M/,"",$6); printf "%.1f", $6/1024 }')
  H_SWAP_TOTAL_GB=${H_SWAP_TOTAL_GB:-0.0}
  H_SWAP_USED_GB=${H_SWAP_USED_GB:-0.0}

  H_UPTIME_STR=$(uptime | awk -F'up ' '{split($2,a,","); print a[1]}' | sed 's/^ *//; s/ *$//')

  # kern.boottime → "{ sec = 1747500000, usec = 0 } Sat May 17 ..."
  boot_epoch=$(sysctl -n kern.boottime 2>/dev/null \
    | awk -F'[ =,]+' '{ for (i=1; i<=NF; i++) if ($i == "sec") { print $(i+1); exit } }')
  now_epoch=$(date '+%s')
  if [[ -n "${boot_epoch:-}" && "$boot_epoch" =~ ^[0-9]+$ ]]; then
    H_UPTIME_SECONDS=$(( now_epoch - boot_epoch ))
  else
    H_UPTIME_SECONDS=0
  fi
}

build_header() {
  local cpu_bar mem_bar swap_bar swap_pct swap_pct_str
  local cpu_annot mem_annot swap_annot
  local term_w big_annot_w cpu_annot_w
  local cpu_w mem_w swap_w load_w

  cpu_annot=$(printf 'user %s%% · sys %s%% · idle %s%%' "$H_CPU_USER" "$H_CPU_SYS" "$H_CPU_IDLE")
  mem_annot=$(printf 'app %s · wired %s · compressed %s · free %s  /  %s' \
    "$(human_mb "$H_MEM_APP_MB")"   "$(human_mb "$H_MEM_WIRED_MB")" \
    "$(human_mb "$H_MEM_COMP_MB")"  "$(human_mb "$H_MEM_FREE_MB")" \
    "$(human_mb "$H_MEM_TOTAL_MB")")

  if awk -v t="$H_SWAP_TOTAL_GB" 'BEGIN { exit (t > 0 ? 0 : 1) }'; then
    swap_pct=$(awk -v u="$H_SWAP_USED_GB" -v t="$H_SWAP_TOTAL_GB" 'BEGIN { printf "%d", u/t*100 }')
    swap_pct_str="${swap_pct}%"
  else
    swap_pct_str="disabled"
  fi
  swap_annot=$(printf '%s / %s GB (%s)' "$H_SWAP_USED_GB" "$H_SWAP_TOTAL_GB" "$swap_pct_str")

  # Sizing: header rows render as "  %-8s %s  %s" → fixed 15 chars + bar(W+2) + annot.
  # Pin bar width to fit the longest annotation (Memory in practice). Cap [10, 40].
  term_w=$(get_cols)
  big_annot_w=$(vis_len "$mem_annot")
  cpu_annot_w=$(vis_len "$cpu_annot")
  if (( cpu_annot_w > big_annot_w )); then big_annot_w=$cpu_annot_w; fi
  cpu_w=$(( term_w - 15 - big_annot_w ))
  if (( cpu_w < 10 )); then cpu_w=10; fi
  if (( cpu_w > 40 )); then cpu_w=40; fi
  mem_w=$cpu_w
  swap_w=$cpu_w

  # Load row layout: "  %-8s %-3s %-7s%s  %s" → 26 chars + bar(W+2) + annot (max "saturated"=9).
  load_w=$(( term_w - 26 - 9 ))
  if (( load_w < 5 )); then load_w=5; fi
  if (( load_w > 20 )); then load_w=20; fi

  printf '\n'
  printf 'Activity Monitor — %s\n\n' "$H_NOW_HMS"

  build_load_row "Load" "1m"  "$H_LOAD1"  "$H_HW_NCPU" "$load_w"
  build_load_row ""     "5m"  "$H_LOAD5"  "$H_HW_NCPU" "$load_w"
  build_load_row ""     "15m" "$H_LOAD15" "$H_HW_NCPU" "$load_w"

  cpu_bar=$(make_bar "$cpu_w" 100 "${H_CPU_USER}:█" "${H_CPU_SYS}:▒")
  printf '  %-8s %s  %s\n' "CPU" "$cpu_bar" "$cpu_annot"

  mem_bar=$(make_bar "$mem_w" "$H_MEM_TOTAL_MB" \
    "${H_MEM_APP_MB}:█" "${H_MEM_WIRED_MB}:▓" "${H_MEM_COMP_MB}:▒")
  # Memory alert is on *free* memory shrinking (inverse): low free → red.
  # color_for() is "value > threshold", so invert by negating both sides.
  local mem_free_pct mem_color
  mem_free_pct=$(awk -v f="$H_MEM_FREE_MB" -v t="$H_MEM_TOTAL_MB" \
    'BEGIN { if (t > 0) printf "%.2f", f/t*100; else print "100" }')
  mem_color=$(awk -v p="$mem_free_pct" \
    -v r="$THRESH_MEMFREE_RED_PCT" -v y="$THRESH_MEMFREE_YEL_PCT" \
    -v cr="$C_RED" -v cy="$C_YEL" 'BEGIN {
      if (p + 0 < r + 0)      printf "%s", cr
      else if (p + 0 < y + 0) printf "%s", cy
    }')
  if [[ -n "$mem_color" ]]; then
    printf '  %-8s %s%s%s  %s%s%s\n' "Memory" \
      "$mem_color" "$mem_bar" "$C_RST" "$mem_color" "$mem_annot" "$C_RST"
  else
    printf '  %-8s %s  %s\n' "Memory" "$mem_bar" "$mem_annot"
  fi

  if awk -v t="$H_SWAP_TOTAL_GB" 'BEGIN { exit (t > 0 ? 0 : 1) }'; then
    swap_bar=$(make_bar "$swap_w" "$H_SWAP_TOTAL_GB" "${H_SWAP_USED_GB}:█")
  else
    swap_bar=$(make_bar "$swap_w" 1 "0:█")
  fi
  local swap_color=""
  if [[ "$swap_pct_str" != "disabled" ]]; then
    swap_color=$(color_for "${swap_pct:-0}" "$THRESH_SWAP_RED" "$THRESH_SWAP_YEL")
  fi
  if [[ -n "$swap_color" ]]; then
    printf '  %-8s %s%s%s  %s%s%s\n' "Swap" \
      "$swap_color" "$swap_bar" "$C_RST" "$swap_color" "$swap_annot" "$C_RST"
  else
    printf '  %-8s %s  %s\n' "Swap" "$swap_bar" "$swap_annot"
  fi

  printf '  %-8s %s · %s cores · Uptime %s\n' "Hardware" "$H_HW_MODEL" "$H_HW_NCPU" "$H_UPTIME_STR"
  printf '\n'
}

# Emit the header object portion of the JSON output (always-present keys).
# Trailing comma is included only when top_* arrays will follow.
build_header_json() {
  local trailing="$1"
  local swap_total_gb_num swap_used_gb_num hw_model_esc

  hw_model_esc=${H_HW_MODEL//\\/\\\\}
  hw_model_esc=${hw_model_esc//\"/\\\"}

  swap_total_gb_num=$(awk -v v="$H_SWAP_TOTAL_GB" 'BEGIN { printf "%.2f", v + 0 }')
  swap_used_gb_num=$(awk  -v v="$H_SWAP_USED_GB"  'BEGIN { printf "%.2f", v + 0 }')

  printf '{\n'
  printf '  "timestamp": "%s",\n' "$H_TIMESTAMP"
  printf '  "host": {"model": "%s", "ncpu": %d, "uptime_seconds": %d, "total_mem_mb": %d},\n' \
    "$hw_model_esc" "$H_HW_NCPU" "$H_UPTIME_SECONDS" "$H_MEM_TOTAL_MB"
  printf '  "load": {"1m": %s, "5m": %s, "15m": %s},\n' \
    "$(awk -v v="$H_LOAD1"  'BEGIN { printf "%.2f", v + 0 }')" \
    "$(awk -v v="$H_LOAD5"  'BEGIN { printf "%.2f", v + 0 }')" \
    "$(awk -v v="$H_LOAD15" 'BEGIN { printf "%.2f", v + 0 }')"
  printf '  "cpu": {"user_pct": %s, "sys_pct": %s, "idle_pct": %s},\n' \
    "$(awk -v v="$H_CPU_USER" 'BEGIN { printf "%.2f", v + 0 }')" \
    "$(awk -v v="$H_CPU_SYS"  'BEGIN { printf "%.2f", v + 0 }')" \
    "$(awk -v v="$H_CPU_IDLE" 'BEGIN { printf "%.2f", v + 0 }')"
  printf '  "memory": {"app_mb": %d, "wired_mb": %d, "compressed_mb": %d, "free_mb": %d, "total_mb": %d},\n' \
    "$H_MEM_APP_MB" "$H_MEM_WIRED_MB" "$H_MEM_COMP_MB" "$H_MEM_FREE_MB" "$H_MEM_TOTAL_MB"

  if [[ "$trailing" -eq 1 ]]; then
    printf '  "swap": {"used_gb": %s, "total_gb": %s},\n' "$swap_used_gb_num" "$swap_total_gb_num"
  else
    printf '  "swap": {"used_gb": %s, "total_gb": %s}\n' "$swap_used_gb_num" "$swap_total_gb_num"
  fi
}

# Emit a JSON array of {pid, command, <val_key>} for one section, sourced
# from TOP_SNAPSHOT + PID_MAP and honoring filter/min.
# Args: KEY ("top_cpu" etc.), VAL_COL (%CPU|MEM|POWER), VAL_KEY,
#       N, PID_MAP, FILTER, MIN_VAL, TRAILING_COMMA (0|1)
build_section_json() {
  local key="$1" val_col="$2" val_key="$3" n="$4" pid_map="$5" filter="$6" min_val="$7" trailing="$8"

  printf '  "%s": [' "$key"

  printf '%s\n' "$TOP_SNAPSHOT" \
    | awk -v vcol="$val_col" -v vkey="$val_key" -v topn="$n" -v pid_map="$pid_map" \
          -v filter="$filter" -v min_val="$min_val" '
      function mem_to_mb(s,    n) {
        n = s + 0
        if (s ~ /K$/) return n / 1024
        if (s ~ /G$/) return n * 1024
        if (s ~ /T$/) return n * 1024 * 1024
        return n
      }
      function trim(s) {
        gsub(/^[[:space:]]+|[[:space:]]+$/, "", s)
        return s
      }
      function jesc(s,    out, i, c, code) {
        out = ""
        for (i = 1; i <= length(s); i++) {
          c = substr(s, i, 1)
          if      (c == "\\") { out = out "\\\\"; continue }
          else if (c == "\"") { out = out "\\\""; continue }
          else if (c == "\b") { out = out "\\b";  continue }
          else if (c == "\f") { out = out "\\f";  continue }
          else if (c == "\n") { out = out "\\n";  continue }
          else if (c == "\r") { out = out "\\r";  continue }
          else if (c == "\t") { out = out "\\t";  continue }
          code = ord[c] + 0
          if (code > 0 && code < 32) out = out sprintf("\\u%04x", code)
          else                       out = out c
        }
        return out
      }

      BEGIN {
        nrows = 0; in_data = 0
        for (i = 1; i < 128; i++) ord[sprintf("%c", i)] = i
        if (pid_map != "") {
          while ((getline line < pid_map) > 0) {
            tab = index(line, "\t")
            if (tab > 0) {
              p = substr(line, 1, tab - 1)
              nm = substr(line, tab + 1)
              pid_name[p] = nm
            }
          }
          close(pid_map)
        }
      }

      /^PID/ && /COMMAND/ {
        pid_p = index($0, "PID")
        cmd_p = index($0, "COMMAND")
        cpu_p = index($0, "%CPU")
        mem_p = index($0, "MEM")
        pwr_p = index($0, "POWER")
        in_data = 1
        next
      }

      in_data && pid_p {
        pid     = trim(substr($0, pid_p, cmd_p - pid_p))
        cmd     = trim(substr($0, cmd_p, cpu_p - cmd_p))
        if (pid in pid_name) cmd = pid_name[pid]
        cpu_str = trim(substr($0, cpu_p, mem_p - cpu_p))
        mem_str = trim(substr($0, mem_p, pwr_p - mem_p))
        pwr_str = trim(substr($0, pwr_p))
        sub(/[+-]$/, "", cpu_str)
        sub(/[+-]$/, "", mem_str)
        sub(/[+-]$/, "", pwr_str)

        if (vcol == "%CPU")     val_num = cpu_str + 0
        else if (vcol == "MEM") val_num = mem_to_mb(mem_str)
        else                    val_num = pwr_str + 0

        if (filter != "" && tolower(cmd) !~ tolower(filter)) next
        if (min_val != "" && val_num + 0 < min_val + 0) next

        nrows++
        v_num[nrows] = val_num
        v_pid[nrows] = pid
        v_cmd[nrows] = cmd
      }

      END {
        if (topn > nrows) topn = nrows
        for (i = 1; i <= topn; i++) {
          best = i
          for (j = i + 1; j <= nrows; j++) {
            if (v_num[j] > v_num[best]) best = j
          }
          if (best != i) {
            tn = v_num[i]; v_num[i] = v_num[best]; v_num[best] = tn
            tp = v_pid[i]; v_pid[i] = v_pid[best]; v_pid[best] = tp
            tc = v_cmd[i]; v_cmd[i] = v_cmd[best]; v_cmd[best] = tc
          }
        }

        for (i = 1; i <= topn; i++) {
          if (i > 1) printf ","
          printf "\n    {\"pid\": %d, \"command\": \"%s\", \"%s\": %.2f}", \
            v_pid[i] + 0, jesc(v_cmd[i]), vkey, v_num[i]
        }
        if (topn > 0) printf "\n  "
      }
    '

  if [[ "$trailing" -eq 1 ]]; then
    printf '],\n'
  else
    printf ']\n'
  fi
}

is_nonneg_number() {
  # accept integers or decimals: 0, 5, 0.5, 12.34
  [[ "$1" =~ ^[0-9]+(\.[0-9]+)?$ ]]
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    -n|--top)
      [[ $# -ge 2 ]] || die "$1 requires a number"
      [[ "$2" =~ ^[1-9][0-9]*$ ]] || die "$1 must be a positive integer (got: $2)"
      TOP_N="$2"
      shift 2
      ;;
    -c|--cpu)
      SHOW_CPU=1
      EXPLICIT_METRIC=1
      shift
      ;;
    -m|--memory|--mem)
      SHOW_MEM=1
      EXPLICIT_METRIC=1
      shift
      ;;
    -e|--energy|--power)
      SHOW_ENERGY=1
      EXPLICIT_METRIC=1
      shift
      ;;
    --no-color|--no-colour)
      NO_COLOR_FLAG=1
      shift
      ;;
    -f|--filter)
      [[ $# -ge 2 ]] || die "$1 requires a pattern"
      FILTER="$2"
      shift 2
      ;;
    -t|--threshold)
      [[ $# -ge 2 ]] || die "$1 requires a number"
      is_nonneg_number "$2" || die "$1 must be a non-negative number (got: $2)"
      THRESHOLD="$2"
      shift 2
      ;;
    --cpu-min)
      [[ $# -ge 2 ]] || die "$1 requires a number"
      is_nonneg_number "$2" || die "$1 must be a non-negative number (got: $2)"
      CPU_MIN="$2"
      shift 2
      ;;
    --mem-min|--memory-min)
      [[ $# -ge 2 ]] || die "$1 requires a number"
      is_nonneg_number "$2" || die "$1 must be a non-negative number (got: $2)"
      MEM_MIN="$2"
      shift 2
      ;;
    --energy-min|--power-min)
      [[ $# -ge 2 ]] || die "$1 requires a number"
      is_nonneg_number "$2" || die "$1 must be a non-negative number (got: $2)"
      ENERGY_MIN="$2"
      shift 2
      ;;
    -j|--json)
      JSON_FLAG=1
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    -V|--version)
      echo "actmon ${VERSION}"
      exit 0
      ;;
    *)
      die "unknown option: $1"
      ;;
  esac
done

if [[ $EXPLICIT_METRIC -eq 0 ]]; then
  SHOW_CPU=1
  SHOW_MEM=1
  SHOW_ENERGY=1
fi

# Per-section minimums fall back to the broadcast --threshold if unset.
[[ -z "$CPU_MIN"    ]] && CPU_MIN="$THRESHOLD"
[[ -z "$MEM_MIN"    ]] && MEM_MIN="$THRESHOLD"
[[ -z "$ENERGY_MIN" ]] && ENERGY_MIN="$THRESHOLD"

collect_header_data

if (( SHOW_CPU || SHOW_MEM || SHOW_ENERGY )); then
  capture_top_snapshot
  PID_MAP=$(mktemp -t actmon.pidmap.XXXXXX)
  trap 'rm -f "$PID_MAP"' EXIT
  build_pid_name_map > "$PID_MAP"
fi

if [[ $JSON_FLAG -eq 1 ]]; then
  any_section=0
  (( SHOW_CPU || SHOW_MEM || SHOW_ENERGY )) && any_section=1
  build_header_json "$any_section"
  if [[ $any_section -eq 1 ]]; then
    # Track how many sections remain so we can emit the trailing comma
    # on all but the last entry.
    remaining=0
    [[ $SHOW_CPU    -eq 1 ]] && (( remaining++ ))
    [[ $SHOW_MEM    -eq 1 ]] && (( remaining++ ))
    [[ $SHOW_ENERGY -eq 1 ]] && (( remaining++ ))
    if [[ $SHOW_CPU -eq 1 ]]; then
      (( remaining-- ))
      build_section_json "top_cpu"    "%CPU"  "cpu_pct" "$TOP_N" "${PID_MAP:-}" "$FILTER" "$CPU_MIN" \
        $(( remaining > 0 ? 1 : 0 ))
    fi
    if [[ $SHOW_MEM -eq 1 ]]; then
      (( remaining-- ))
      build_section_json "top_memory" "MEM"   "mem_mb"  "$TOP_N" "${PID_MAP:-}" "$FILTER" "$MEM_MIN" \
        $(( remaining > 0 ? 1 : 0 ))
    fi
    if [[ $SHOW_ENERGY -eq 1 ]]; then
      (( remaining-- ))
      build_section_json "top_energy" "POWER" "power"   "$TOP_N" "${PID_MAP:-}" "$FILTER" "$ENERGY_MIN" \
        $(( remaining > 0 ? 1 : 0 ))
    fi
  fi
  printf '}\n'
else
  init_colors
  build_header
  [[ $SHOW_CPU    -eq 1 ]] && build_section "TOP CPU"    "%CPU"  "$TOP_N" "${PID_MAP:-}" "$FILTER" "$CPU_MIN"
  [[ $SHOW_MEM    -eq 1 ]] && build_section "TOP MEMORY" "MEM"   "$TOP_N" "${PID_MAP:-}" "$FILTER" "$MEM_MIN"
  [[ $SHOW_ENERGY -eq 1 ]] && build_section "TOP ENERGY" "POWER" "$TOP_N" "${PID_MAP:-}" "$FILTER" "$ENERGY_MIN"
fi
true  # ensure final exit code is 0 even if last section was disabled
