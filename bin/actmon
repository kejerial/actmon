#!/usr/bin/env bash
#
# actmon — terminal Activity Monitor for macOS
# https://github.com/kejerial/actmon
#
set -euo pipefail

VERSION="0.1.0"
TOP_N=10
SHOW_CPU=0
SHOW_MEM=0
SHOW_ENERGY=0
EXPLICIT_METRIC=0  # set when any --cpu/--memory/--energy flag is used

usage() {
  cat <<'EOF'
actmon — terminal Activity Monitor for macOS

USAGE
  actmon [options]

OPTIONS
  -n, --top N        number of processes per section (default: 10)
  -c, --cpu          show only the CPU section
  -m, --memory       show only the memory section
  -e, --energy       show only the energy section
  -h, --help         show this help

EXAMPLES
  actmon                       full dashboard, top 10 each
  actmon --top 5               top 5 per section
  actmon --memory              only memory section
  actmon --cpu --energy        CPU + energy (no memory)

NOTES
  • Multiple metric flags can be combined.
  • The system summary header is always shown.
  • macOS only (uses BSD `top -stats`).
EOF
}

die() {
  echo "actmon: $*" >&2
  echo "       try 'actmon --help'" >&2
  exit 2
}

build_section() {
  local title="$1" sort="$2" val_col="$3" n="$4"

  printf '%s\n' "$title"

  # -l 2: two samples so CPU% is a meaningful delta (single sample reports
  # 0.0 for everything since there's no prior to diff against). -s 1 = 1s
  # between samples (top requires an integer here).
  top -l 2 -s 1 -n "$n" -o "$sort" -stats pid,command,cpu,mem,power 2>/dev/null \
    | awk 'BEGIN { sample = 0 }
           /^Processes:/ { sample++ }
           sample == 2' \
    | awk -v vcol="$val_col" -v width=20 '
      function make_bar(len,    s, i) {
        s = ""
        for (i = 1; i <= width; i++) s = s (i <= len ? "█" : "░")
        return s
      }
      function mem_to_mb(s,    n) {
        n = s + 0
        if (s ~ /K$/) return n / 1024
        if (s ~ /G$/) return n * 1024
        if (s ~ /T$/) return n * 1024 * 1024
        return n
      }
      function trim(s) {
        gsub(/^[[:space:]]+|[[:space:]]+$/, "", s)
        return s
      }

      BEGIN { row = 0; in_data = 0 }

      /^PID/ && /COMMAND/ {
        pid_p = index($0, "PID")
        cmd_p = index($0, "COMMAND")
        cpu_p = index($0, "%CPU")
        mem_p = index($0, "MEM")
        pwr_p = index($0, "POWER")
        in_data = 1
        next
      }

      in_data && pid_p {
        pid     = trim(substr($0, pid_p, cmd_p - pid_p))
        cmd     = trim(substr($0, cmd_p, cpu_p - cmd_p))
        cpu_str = trim(substr($0, cpu_p, mem_p - cpu_p))
        mem_str = trim(substr($0, mem_p, pwr_p - mem_p))
        pwr_str = trim(substr($0, pwr_p))

        if (vcol == "%CPU") {
          val_num  = cpu_str + 0
          val_disp = sprintf("%5.1f%%", val_num)
        } else if (vcol == "MEM") {
          val_num  = mem_to_mb(mem_str)
          val_disp = sprintf("%6s", mem_str)
        } else {
          val_num  = pwr_str + 0
          val_disp = sprintf("%6.1f", val_num)
        }

        row++
        if (row == 1) max_val = (val_num > 0 ? val_num : 1)
        bar_cells = int(val_num / max_val * width)
        if (bar_cells > width) bar_cells = width
        if (bar_cells < 0)     bar_cells = 0

        if (length(cmd) > 24) cmd = substr(cmd, 1, 23) "…"

        printf "  %-7s  %-24s  %s  %s\n", pid, cmd, val_disp, make_bar(bar_cells)
      }
    '
  printf '\n'
}

build_header() {
  local now top_h load cpu mem mem_used mem_unused
  local hw_model hw_ncpu hw_total_gb
  local swap_total swap_used up

  now=$(date '+%H:%M:%S')
  top_h=$(top -l 1 -n 0 2>/dev/null)

  load=$(awk -F': ' '/^Load Avg:/ { sub(/[[:space:]]+$/,"",$2); print $2 }' <<<"$top_h")
  cpu=$(awk -F': ' '/^CPU usage:/ { sub(/[[:space:]]+$/,"",$2); print $2 }' <<<"$top_h")
  mem=$(awk -F': ' '/^PhysMem:/ { sub(/[[:space:]]+$/,"",$2); print $2 }' <<<"$top_h")
  mem_used=$(awk '{print $1}' <<<"$mem")
  mem_unused=$(sed -E 's/.*, ([0-9]+[MG]) unused\..*/\1/' <<<"$mem")

  hw_model=$(sysctl -n hw.model)
  hw_ncpu=$(sysctl -n hw.ncpu)
  hw_total_gb=$(awk -v b="$(sysctl -n hw.memsize)" 'BEGIN { printf "%.1f", b/1073741824 }')

  swap_total=$(sysctl -n vm.swapusage 2>/dev/null | awk '{ gsub(/M/,"",$3); printf "%.1f", $3/1024 }')
  swap_used=$(sysctl -n vm.swapusage 2>/dev/null | awk '{ gsub(/M/,"",$6); printf "%.1f", $6/1024 }')
  swap_total=${swap_total:-0.0}
  swap_used=${swap_used:-0.0}

  up=$(uptime | awk -F'up ' '{split($2,a,","); print a[1]}' | sed 's/^ *//; s/ *$//')

  printf '\n'
  printf 'Activity Monitor — %s\n' "$now"
  printf '\n'
  printf '  Load       %s\n' "$load"
  printf '  CPU        %s\n' "$cpu"
  printf '  Memory     %s used · %s free  ·  %s GB total\n' "$mem_used" "$mem_unused" "$hw_total_gb"
  printf '  Swap       %s / %s GB used\n' "$swap_used" "$swap_total"
  printf '  Hardware   %s · %s cores  ·  Uptime %s\n' "$hw_model" "$hw_ncpu" "$up"
  printf '\n'
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    -n|--top)
      [[ $# -ge 2 ]] || die "$1 requires a number"
      [[ "$2" =~ ^[1-9][0-9]*$ ]] || die "$1 must be a positive integer (got: $2)"
      TOP_N="$2"
      shift 2
      ;;
    -c|--cpu)
      SHOW_CPU=1
      EXPLICIT_METRIC=1
      shift
      ;;
    -m|--memory|--mem)
      SHOW_MEM=1
      EXPLICIT_METRIC=1
      shift
      ;;
    -e|--energy|--power)
      SHOW_ENERGY=1
      EXPLICIT_METRIC=1
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    -V|--version)
      echo "actmon ${VERSION}"
      exit 0
      ;;
    *)
      die "unknown option: $1"
      ;;
  esac
done

if [[ $EXPLICIT_METRIC -eq 0 ]]; then
  SHOW_CPU=1
  SHOW_MEM=1
  SHOW_ENERGY=1
fi

build_header

build_section "TOP CPU" cpu "%CPU" "$TOP_N"

# TODO(commits 5-7): memory + energy sections, gated by metric flags
[[ $SHOW_MEM -eq 1 || $SHOW_ENERGY -eq 1 ]] && \
  printf '  (memory + energy sections coming next)\n\n'
