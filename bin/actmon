#!/usr/bin/env bash
#
# actmon — terminal Activity Monitor for macOS
# https://github.com/kejerial/actmon
#
set -euo pipefail

VERSION="0.1.0"
TOP_N=10
SHOW_CPU=0
SHOW_MEM=0
SHOW_ENERGY=0
EXPLICIT_METRIC=0  # set when any --cpu/--memory/--energy flag is used

usage() {
  cat <<'EOF'
actmon — terminal Activity Monitor for macOS

USAGE
  actmon [options]

OPTIONS
  -n, --top N        number of processes per section (default: 10)
  -c, --cpu          show only the CPU section
  -m, --memory       show only the memory section
  -e, --energy       show only the energy section
  -h, --help         show this help

EXAMPLES
  actmon                       full dashboard, top 10 each
  actmon --top 5               top 5 per section
  actmon --memory              only memory section
  actmon --cpu --energy        CPU + energy (no memory)

NOTES
  • Multiple metric flags can be combined.
  • The system summary header is always shown.
  • macOS only (uses BSD `top -stats`).
EOF
}

die() {
  echo "actmon: $*" >&2
  echo "       try 'actmon --help'" >&2
  exit 2
}

build_header() {
  local now top_h load cpu mem mem_used mem_unused
  local hw_model hw_ncpu hw_total_gb
  local swap_total swap_used up

  now=$(date '+%H:%M:%S')
  top_h=$(top -l 1 -n 0 2>/dev/null)

  load=$(awk -F': ' '/^Load Avg:/ { sub(/[[:space:]]+$/,"",$2); print $2 }' <<<"$top_h")
  cpu=$(awk -F': ' '/^CPU usage:/ { sub(/[[:space:]]+$/,"",$2); print $2 }' <<<"$top_h")
  mem=$(awk -F': ' '/^PhysMem:/ { sub(/[[:space:]]+$/,"",$2); print $2 }' <<<"$top_h")
  mem_used=$(awk '{print $1}' <<<"$mem")
  mem_unused=$(sed -E 's/.*, ([0-9]+[MG]) unused\..*/\1/' <<<"$mem")

  hw_model=$(sysctl -n hw.model)
  hw_ncpu=$(sysctl -n hw.ncpu)
  hw_total_gb=$(awk -v b="$(sysctl -n hw.memsize)" 'BEGIN { printf "%.1f", b/1073741824 }')

  swap_total=$(sysctl -n vm.swapusage 2>/dev/null | awk '{ gsub(/M/,"",$3); printf "%.1f", $3/1024 }')
  swap_used=$(sysctl -n vm.swapusage 2>/dev/null | awk '{ gsub(/M/,"",$6); printf "%.1f", $6/1024 }')
  swap_total=${swap_total:-0.0}
  swap_used=${swap_used:-0.0}

  up=$(uptime | awk -F'up ' '{split($2,a,","); print a[1]}' | sed 's/^ *//; s/ *$//')

  printf '\n'
  printf 'Activity Monitor — %s\n' "$now"
  printf '\n'
  printf '  Load       %s\n' "$load"
  printf '  CPU        %s\n' "$cpu"
  printf '  Memory     %s used · %s free  ·  %s GB total\n' "$mem_used" "$mem_unused" "$hw_total_gb"
  printf '  Swap       %s / %s GB used\n' "$swap_used" "$swap_total"
  printf '  Hardware   %s · %s cores  ·  Uptime %s\n' "$hw_model" "$hw_ncpu" "$up"
  printf '\n'
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    -n|--top)
      [[ $# -ge 2 ]] || die "$1 requires a number"
      [[ "$2" =~ ^[1-9][0-9]*$ ]] || die "$1 must be a positive integer (got: $2)"
      TOP_N="$2"
      shift 2
      ;;
    -c|--cpu)
      SHOW_CPU=1
      EXPLICIT_METRIC=1
      shift
      ;;
    -m|--memory|--mem)
      SHOW_MEM=1
      EXPLICIT_METRIC=1
      shift
      ;;
    -e|--energy|--power)
      SHOW_ENERGY=1
      EXPLICIT_METRIC=1
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    -V|--version)
      echo "actmon ${VERSION}"
      exit 0
      ;;
    *)
      die "unknown option: $1"
      ;;
  esac
done

if [[ $EXPLICIT_METRIC -eq 0 ]]; then
  SHOW_CPU=1
  SHOW_MEM=1
  SHOW_ENERGY=1
fi

build_header

# TODO(commits 4-7): per-metric sections
printf '  (sections coming next: cpu=%d mem=%d energy=%d, top=%d)\n\n' \
  "$SHOW_CPU" "$SHOW_MEM" "$SHOW_ENERGY" "$TOP_N"
