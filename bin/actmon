#!/usr/bin/env bash
#
# actmon — terminal Activity Monitor for macOS
# https://github.com/kejerial/actmon
#
set -euo pipefail

VERSION="0.1.0"
TOP_N=10
SHOW_CPU=0
SHOW_MEM=0
SHOW_ENERGY=0
EXPLICIT_METRIC=0  # set when any --cpu/--memory/--energy flag is used

usage() {
  cat <<'EOF'
actmon — terminal Activity Monitor for macOS

USAGE
  actmon [options]

OPTIONS
  -n, --top N        number of processes per section (default: 10)
  -c, --cpu          show only the CPU section
  -m, --memory       show only the memory section
  -e, --energy       show only the energy section
  -h, --help         show this help

EXAMPLES
  actmon                       full dashboard, top 10 each
  actmon --top 5               top 5 per section
  actmon --memory              only memory section
  actmon --cpu --energy        CPU + energy (no memory)

NOTES
  • Multiple metric flags can be combined.
  • The system summary header is always shown.
  • macOS only (uses BSD `top -stats`).
EOF
}

die() {
  echo "actmon: $*" >&2
  echo "       try 'actmon --help'" >&2
  exit 2
}

build_section() {
  local title="$1" sort="$2" val_col="$3" n="$4"

  printf '%s\n' "$title"

  # -l 2: two samples so CPU% is a meaningful delta (single sample reports
  # 0.0 for everything since there's no prior to diff against). -s 1 = 1s
  # between samples (top requires an integer here).
  top -l 2 -s 1 -n "$n" -o "$sort" -stats pid,command,cpu,mem,power 2>/dev/null \
    | awk 'BEGIN { sample = 0 }
           /^Processes:/ { sample++ }
           sample == 2' \
    | awk -v vcol="$val_col" -v width=20 '
      function make_bar(len,    s, i) {
        s = ""
        for (i = 1; i <= width; i++) s = s (i <= len ? "█" : "░")
        return s
      }
      function mem_to_mb(s,    n) {
        n = s + 0
        if (s ~ /K$/) return n / 1024
        if (s ~ /G$/) return n * 1024
        if (s ~ /T$/) return n * 1024 * 1024
        return n
      }
      function trim(s) {
        gsub(/^[[:space:]]+|[[:space:]]+$/, "", s)
        return s
      }

      BEGIN { row = 0; in_data = 0 }

      /^PID/ && /COMMAND/ {
        pid_p = index($0, "PID")
        cmd_p = index($0, "COMMAND")
        cpu_p = index($0, "%CPU")
        mem_p = index($0, "MEM")
        pwr_p = index($0, "POWER")
        in_data = 1
        next
      }

      in_data && pid_p {
        pid     = trim(substr($0, pid_p, cmd_p - pid_p))
        cmd     = trim(substr($0, cmd_p, cpu_p - cmd_p))
        cpu_str = trim(substr($0, cpu_p, mem_p - cpu_p))
        mem_str = trim(substr($0, mem_p, pwr_p - mem_p))
        pwr_str = trim(substr($0, pwr_p))
        # top -l 2 appends [+-] when a value changed since the prior sample;
        # strip it for clean column alignment and unit parsing.
        sub(/[+-]$/, "", cpu_str)
        sub(/[+-]$/, "", mem_str)
        sub(/[+-]$/, "", pwr_str)

        if (vcol == "%CPU") {
          val_num  = cpu_str + 0
          val_disp = sprintf("%5.1f%%", val_num)
        } else if (vcol == "MEM") {
          val_num  = mem_to_mb(mem_str)
          val_disp = sprintf("%6s", mem_str)
        } else {
          val_num  = pwr_str + 0
          val_disp = sprintf("%6.1f", val_num)
        }

        row++
        if (row == 1) max_val = (val_num > 0 ? val_num : 1)
        bar_cells = int(val_num / max_val * width)
        if (bar_cells > width) bar_cells = width
        if (bar_cells < 0)     bar_cells = 0

        if (length(cmd) > 24) cmd = substr(cmd, 1, 23) "…"

        printf "  %-7s  %-24s  %s  %s\n", pid, cmd, val_disp, make_bar(bar_cells)
      }
    '
  printf '\n'
}

to_mb() {
  awk -v s="$1" 'BEGIN {
    n = s + 0
    if      (s ~ /K$/) printf "%.0f", n / 1024
    else if (s ~ /G$/) printf "%.0f", n * 1024
    else if (s ~ /T$/) printf "%.0f", n * 1024 * 1024
    else               printf "%.0f", n
  }'
}

human_mb() {
  awk -v m="$1" 'BEGIN {
    if (m+0 >= 1024) printf "%dG", (m/1024) + 0.5
    else             printf "%dM", m+0
  }'
}

# make_bar WIDTH DENOM PAIR1 [PAIR2 ...]
# Each PAIR is "value:glyph". Cells per pair = round(value/denom*width).
# Overflow is clamped, leftover is padded with ░. Output: ▕…▏ (no newline).
make_bar() {
  awk -v width="$1" -v denom="$2" -v args="$*" '
    BEGIN {
      n = split(args, a, " ")
      out = ""
      used = 0
      for (i = 3; i <= n; i++) {
        if (split(a[i], part, ":") < 2) continue
        v = part[1] + 0
        g = part[2]
        cells = int(v / denom * width + 0.5)
        if (used + cells > width) cells = width - used
        if (cells < 0) cells = 0
        for (j = 0; j < cells; j++) out = out g
        used += cells
      }
      while (used < width) { out = out "░"; used++ }
      printf "▕%s▏", out
    }'
}

build_load_row() {
  local label="$1" period="$2" loadv="$3" ncpu="$4" width="$5"
  local bar pct_str
  bar=$(make_bar "$width" "$ncpu" "${loadv}:█")
  pct_str=$(awk -v l="$loadv" -v n="$ncpu" 'BEGIN {
    r = l / n
    if (r >= 1.0) print "saturated"
    else          printf "%d%%", r * 100
  }')
  printf '  %-8s %-3s %-7s%s  %s\n' "$label" "$period" "$loadv" "$bar" "$pct_str"
}

build_header() {
  local now top_h
  local load_raw load1 load5 load15
  local cpu_user cpu_sys cpu_idle cpu_bar
  local mem_line mu mw mc
  local mem_used_mb mem_wired_mb mem_comp_mb mem_app_mb mem_free_mb mem_total_mb mem_bar
  local hw_model hw_ncpu hw_total_gb hw_memsize
  local swap_total_gb swap_used_gb swap_pct swap_bar swap_pct_str
  local up
  local cpu_w=40 mem_w=40 swap_w=40 load_w=20

  now=$(date '+%H:%M:%S')
  top_h=$(top -l 1 -n 0 2>/dev/null)

  load_raw=$(awk -F': ' '/^Load Avg:/ { sub(/[[:space:]]+$/,"",$2); print $2 }' <<<"$top_h")
  IFS=', ' read -r load1 load5 load15 <<<"$load_raw"

  cpu_user=$(awk -F'[ ,%]+' '/^CPU usage:/ { print $3 }' <<<"$top_h")
  cpu_sys=$(awk  -F'[ ,%]+' '/^CPU usage:/ { print $5 }' <<<"$top_h")
  cpu_idle=$(awk -F'[ ,%]+' '/^CPU usage:/ { print $7 }' <<<"$top_h")

  # PhysMem: <U> used (<W> wired, <C> compressor), <F> unused.
  mem_line=$(awk '/^PhysMem:/' <<<"$top_h")
  mu=$(sed -E 's/^PhysMem: ([0-9]+[KMGT]?).*/\1/'           <<<"$mem_line")
  mw=$(sed -E 's/.*\(([0-9]+[KMGT]?) wired.*/\1/'           <<<"$mem_line")
  mc=$(sed -E 's/.*wired, ([0-9]+[KMGT]?) compressor.*/\1/' <<<"$mem_line")
  mem_used_mb=$(to_mb "$mu")
  mem_wired_mb=$(to_mb "$mw")
  mem_comp_mb=$(to_mb "$mc")

  hw_memsize=$(sysctl -n hw.memsize)
  mem_total_mb=$(awk -v b="$hw_memsize" 'BEGIN { printf "%.0f", b/1048576 }')
  mem_app_mb=$(( mem_used_mb - mem_wired_mb - mem_comp_mb ))
  if (( mem_app_mb < 0 )); then mem_app_mb=0; fi
  mem_free_mb=$(( mem_total_mb - mem_used_mb ))
  if (( mem_free_mb < 0 )); then mem_free_mb=0; fi

  hw_model=$(sysctl -n hw.model)
  hw_ncpu=$(sysctl -n hw.ncpu)
  hw_total_gb=$(awk -v b="$hw_memsize" 'BEGIN { printf "%.1f", b/1073741824 }')

  swap_total_gb=$(sysctl -n vm.swapusage 2>/dev/null | awk '{ gsub(/M/,"",$3); printf "%.1f", $3/1024 }')
  swap_used_gb=$(sysctl -n vm.swapusage 2>/dev/null  | awk '{ gsub(/M/,"",$6); printf "%.1f", $6/1024 }')
  swap_total_gb=${swap_total_gb:-0.0}
  swap_used_gb=${swap_used_gb:-0.0}

  up=$(uptime | awk -F'up ' '{split($2,a,","); print a[1]}' | sed 's/^ *//; s/ *$//')

  printf '\n'
  printf 'Activity Monitor — %s\n\n' "$now"

  build_load_row "Load" "1m"  "$load1"  "$hw_ncpu" "$load_w"
  build_load_row ""     "5m"  "$load5"  "$hw_ncpu" "$load_w"
  build_load_row ""     "15m" "$load15" "$hw_ncpu" "$load_w"

  cpu_bar=$(make_bar "$cpu_w" 100 "${cpu_user}:█" "${cpu_sys}:▒")
  printf '  %-8s %s  user %s%% · sys %s%% · idle %s%%\n' \
    "CPU" "$cpu_bar" "$cpu_user" "$cpu_sys" "$cpu_idle"

  mem_bar=$(make_bar "$mem_w" "$mem_total_mb" \
    "${mem_app_mb}:█" "${mem_wired_mb}:▓" "${mem_comp_mb}:▒")
  printf '  %-8s %s  app %s · wired %s · compressed %s · free %s  /  %s\n' \
    "Memory" "$mem_bar" \
    "$(human_mb "$mem_app_mb")"   "$(human_mb "$mem_wired_mb")" \
    "$(human_mb "$mem_comp_mb")"  "$(human_mb "$mem_free_mb")" \
    "$(human_mb "$mem_total_mb")"

  if awk -v t="$swap_total_gb" 'BEGIN { exit (t > 0 ? 0 : 1) }'; then
    swap_bar=$(make_bar "$swap_w" "$swap_total_gb" "${swap_used_gb}:█")
    swap_pct=$(awk -v u="$swap_used_gb" -v t="$swap_total_gb" 'BEGIN { printf "%d", u/t*100 }')
    swap_pct_str="${swap_pct}%"
  else
    swap_bar=$(make_bar "$swap_w" 1 "0:█")
    swap_pct_str="disabled"
  fi
  printf '  %-8s %s  %s / %s GB (%s)\n' \
    "Swap" "$swap_bar" "$swap_used_gb" "$swap_total_gb" "$swap_pct_str"

  printf '  %-8s %s · %s cores · Uptime %s\n' "Hardware" "$hw_model" "$hw_ncpu" "$up"
  printf '\n'
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    -n|--top)
      [[ $# -ge 2 ]] || die "$1 requires a number"
      [[ "$2" =~ ^[1-9][0-9]*$ ]] || die "$1 must be a positive integer (got: $2)"
      TOP_N="$2"
      shift 2
      ;;
    -c|--cpu)
      SHOW_CPU=1
      EXPLICIT_METRIC=1
      shift
      ;;
    -m|--memory|--mem)
      SHOW_MEM=1
      EXPLICIT_METRIC=1
      shift
      ;;
    -e|--energy|--power)
      SHOW_ENERGY=1
      EXPLICIT_METRIC=1
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    -V|--version)
      echo "actmon ${VERSION}"
      exit 0
      ;;
    *)
      die "unknown option: $1"
      ;;
  esac
done

if [[ $EXPLICIT_METRIC -eq 0 ]]; then
  SHOW_CPU=1
  SHOW_MEM=1
  SHOW_ENERGY=1
fi

build_header

[[ $SHOW_CPU    -eq 1 ]] && build_section "TOP CPU"    cpu   "%CPU"  "$TOP_N"
[[ $SHOW_MEM    -eq 1 ]] && build_section "TOP MEMORY" mem   "MEM"   "$TOP_N"
[[ $SHOW_ENERGY -eq 1 ]] && build_section "TOP ENERGY" power "POWER" "$TOP_N"
true  # ensure final exit code is 0 even if last section was disabled
